---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  noindex?: boolean;
  pageSchema?: object;
}

const {
  title = "Mobile Car Detailing in McKinney, TX | Factory Reset Detail",
  description = "Premium mobile car detailing in McKinney, TX. Interior, exterior, and full-service detailing brought directly to your driveway. Serving Collin County and surrounding areas.",
  ogTitle,
  ogDescription,
  ogImage: ogImageProp,
  noindex = false,
  pageSchema,
} = Astro.props;

const siteUrl = "https://www.factoryresetdetail.com";
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const defaultOgImage = `${siteUrl}/img/porsche-gt3-front.webp`;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;
const resolvedOgImage = ogImageProp ?? defaultOgImage;

const siteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AutoDetailing",
  "name": "Factory Reset Detail",
  "url": siteUrl,
  "image": `${siteUrl}/img/porsche-gt3-front.webp`,
  "telephone": "+14692798048",
  "priceRange": "$$",
  "areaServed": [
    "McKinney, Texas",
    "Allen, Texas",
    "Frisco, Texas",
    "Plano, Texas",
    "Prosper, Texas",
    "Lucas, Texas",
    "Collin County, Texas",
  ],
  "description": "Premium mobile car detailing in McKinney, Texas. Interior and exterior detailing performed at your home or workplace.",
});

const pageSchemaJson = pageSchema ? JSON.stringify(pageSchema) : null;
---

<!doctype html>
<html lang="en" class="bg-neutral-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="theme-color" content="#0a0a0a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Factory Reset Detail" />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:alt" content="Factory Reset Detail — premium mobile car detailing in McKinney, TX" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content="Factory Reset Detail — premium mobile car detailing in McKinney, TX" />

    <!-- Cormorant Garamond — luxury serif for hero headline -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Structured Data -->
    <script is:inline type="application/ld+json" set:html={siteSchema} />
    {pageSchemaJson && <script is:inline type="application/ld+json" set:html={pageSchemaJson} />}

    <!-- Per-page head injection (e.g. conversion scripts) -->
    <slot name="head" />

    <!-- Google Analytics (GA4) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=G-G3708NRPFL`}></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G3708NRPFL');
    </script>
  </head>

  <body class="min-h-screen bg-neutral-950 text-white antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // --- Event tracking (book_click, phone_click, email_click) ---
      document.addEventListener('click', function (e) {
        var el = e.target.closest('[data-track]');
        if (!el || typeof gtag !== 'function') return;
        gtag('event', el.dataset.track, {
          event_category: 'engagement',
          event_label: el.dataset.trackLabel || el.textContent.trim().slice(0, 60),
        });
      });

      // --- Scroll depth: 75% ---
      var scroll75fired = false;
      window.addEventListener('scroll', function () {
        if (scroll75fired) return;
        var scrolled = window.scrollY + window.innerHeight;
        var total = document.documentElement.scrollHeight;
        if (scrolled / total >= 0.75) {
          scroll75fired = true;
          if (typeof gtag === 'function') {
            gtag('event', 'scroll_75', { event_category: 'engagement' });
          }
        }
      }, { passive: true });
    </script>
  </body>
</html>
