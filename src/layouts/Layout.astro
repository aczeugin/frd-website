---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Mobile Car Detailing in McKinney, TX | Factory Reset Detail",
  description = "Premium mobile car detailing in McKinney, TX. Interior, exterior, and full-service detailing brought directly to your driveway. Serving Collin County and surrounding areas.",
} = Astro.props;

const siteUrl = "https://www.factoryresetdetail.com";
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = `${siteUrl}/img/porsche-gt3-front.webp`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Factory Reset Detail",
  "url": siteUrl,
  "description": "Premium mobile car detailing in McKinney, TX. Paint-safe methods, material-correct finishes, and clear recommendations—brought directly to your driveway.",
  "areaServed": [
    { "@type": "City", "name": "McKinney, Texas" },
    { "@type": "AdministrativeArea", "name": "Collin County, Texas" },
  ],
  "serviceType": "Mobile Car Detailing",
});
---

<!doctype html>
<html lang="en" class="bg-neutral-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0a0a0a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Factory Reset Detail" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Factory Reset Detail — premium mobile car detailing in McKinney, TX" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Factory Reset Detail — premium mobile car detailing in McKinney, TX" />

    <!-- Structured Data -->
    <script is:inline type="application/ld+json" set:html={schema} />

    <!-- Google Analytics (GA4) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=G-G3708NRPFL`}></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G3708NRPFL');
    </script>
  </head>

  <body class="min-h-screen bg-neutral-950 text-white antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
