<section class="frd-hero bg-neutral-950 text-white">
  <div class="mx-auto max-w-7xl px-6 pt-6 pb-8 lg:px-10 lg:pt-10 lg:pb-12 xl:pt-12 xl:pb-14">
    <div class="grid items-center gap-8 lg:grid-cols-12 lg:gap-10 xl:gap-12">
      <div class="lg:col-span-5">
        <p class="text-[11px] uppercase tracking-[0.28em] text-white/60 md:text-xs">
          Mobile Detailing • McKinney, TX
        </p>

        <h1 class="mt-4 max-w-[11ch] text-4xl font-semibold leading-[1.02] md:text-5xl xl:text-[3.65rem]">
          Precision detailing executed with restraint.
        </h1>

        <p class="mt-5 max-w-prose text-base leading-relaxed text-white/70 md:text-lg">
          A material-safe, paint-conscious approach designed to preserve finishes—not push them.
        </p>

        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a
            href="/book"
            class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-medium text-neutral-950 transition hover:opacity-90"
          >
            Book a Detail
          </a>

          <a
            href="/services"
            class="inline-flex items-center justify-center rounded-full border border-white/15 px-6 py-3 text-sm font-medium text-white transition hover:border-white/30 hover:bg-white/5"
          >
            View Services
          </a>
        </div>

        <div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-sm text-white/55">
          <span>Fully mobile</span>
          <span>Collin County</span>
          <span>Paint-safe methods</span>
        </div>
      </div>

      <div class="lg:col-span-7">
        <slot />
      </div>
    </div>
  </div>
</section>
