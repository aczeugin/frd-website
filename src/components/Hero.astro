<section class="frd-hero bg-neutral-950 text-white">
  <div class="mx-auto max-w-7xl px-6 pt-6 pb-6 lg:px-10 lg:pt-10 lg:pb-10 xl:pt-12 xl:pb-12">
    <div class="grid items-center gap-8 lg:grid-cols-12 lg:gap-10 xl:gap-12">
      <div class="lg:col-span-5">
        <p class="text-[11px] uppercase tracking-[0.28em] text-white/60 md:text-xs">
          Mobile Detailing • McKinney, TX
        </p>

        <h1 class="font-cormorant mt-4 text-[2.6rem] font-semibold leading-[1.0] tracking-[-0.01em] md:text-[3.4rem] lg:text-[2.6rem] xl:text-[3.2rem]">
          <span class="lg:block">Premium mobile</span>
          <span class="lg:block">detailing in</span>
          <span class="lg:block">McKinney, Texas.</span>
        </h1>

        <p class="mt-5 max-w-prose text-base leading-relaxed text-white/70 md:text-lg">
          Premium mobile detailing for McKinney and the surrounding Collin County area, with interior
          and exterior care performed at your home, workplace, or wherever the vehicle is parked.
          Material-safe methods, clean finishes, and a service experience built around convenience.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/book"
            class="inline-flex items-center justify-center rounded-full border border-white/20 bg-[#f5f0e8] px-7 py-3.5 text-sm font-medium tracking-[0.06em] text-neutral-900 transition-all duration-300 hover:bg-[#ece6d9] hover:border-white/40"
            data-track="book_click"
            data-track-label="Hero — Book a Detail"
          >
            Book a Detail
          </a>

          <a
            href="/services"
            class="inline-flex items-center justify-center rounded-full border border-white/12 px-7 py-3.5 text-sm font-medium tracking-[0.06em] text-white/70 transition-all duration-300 hover:border-white/30 hover:text-white"
          >
            View Services
          </a>
        </div>

        <div class="mt-6 flex flex-wrap gap-2 text-xs text-white/70">
  <span class="rounded-full border border-white/10 px-3 py-1">
    Mobile service
  </span>

  <span class="rounded-full border border-white/10 px-3 py-1">
    Interior + exterior detailing
  </span>

  <span class="rounded-full border border-white/10 px-3 py-1">
    Paint-safe methods
  </span>

  <span class="rounded-full border border-white/10 px-3 py-1">
    McKinney + Collin County
  </span>
</div>
      </div>

      <div class="lg:col-span-7">
        <slot />
      </div>
    </div>
  </div>
</section>
