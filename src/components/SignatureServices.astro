---
const services = [
  {
    eyebrow: "Maintenance",
    title: "Maintenance Detail",
    desc: "For already well-kept vehicles that need consistent upkeep with a clean, polished finish.",
    image: "/img/gt3-engine.webp",
    alt: "Maintenance Detail service preview",
    primaryHref: "/book?service=maintenance",
    secondaryHref: "/services#packages",
  },
  {
    eyebrow: "Most Popular",
    title: "Signature Detail",
    desc: "A deeper, more complete service designed to leave the vehicle feeling professionally finished.",
    image: "/img/porsche-gt3-front.webp",
    alt: "Signature Detail service preview",
    primaryHref: "/book?service=signature",
    secondaryHref: "/services#packages",
  },
  {
    eyebrow: "Complete Reset",
    title: "Factory Reset Detail",
    desc: "The most comprehensive reset short of correction work, inside and out.",
    image: "/img/gt3-interior.webp",
    alt: "Factory Reset Detail service preview",
    primaryHref: "/book?service=reset",
    secondaryHref: "/services#packages",
  },
];
---

<section class="bg-neutral-950 text-white">
  <div class="mx-auto max-w-7xl px-6 py-18 lg:px-10 lg:py-24">
    <div class="flex items-end justify-between gap-6">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.32em] text-white/45">Services</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-5xl">
          Signature services, built around outcome-driven results.
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/68 md:text-lg">
          Focused packages designed for paint, wheels, glass, and interior—delivered with clear
          recommendations and a professionally finished result.
        </p>
      </div>

      <a
        href="/services"
        class="hidden md:inline-flex items-center rounded-full border border-white/10 bg-white/[0.03] px-5 py-3 text-sm text-white/80 transition hover:border-white/20 hover:bg-white/[0.06] hover:text-white"
      >
        Compare packages
      </a>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {services.map((service) => (
        <article class="overflow-hidden rounded-[1.75rem] border border-white/10 bg-white/[0.03]">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={service.image}
              alt={service.alt}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>

          <div class="p-6">
            <p class="text-[11px] uppercase tracking-[0.28em] text-white/45">{service.eyebrow}</p>

            <h3 class="mt-3 text-2xl font-medium text-white">{service.title}</h3>

            <p class="mt-4 text-sm leading-relaxed text-white/68">
              {service.desc}
            </p>

            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href={service.primaryHref}
                class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-medium text-neutral-950 transition hover:opacity-90"
              >
                Book now
              </a>

              <a
                href={service.secondaryHref}
                class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/[0.03] px-5 py-3 text-sm text-white/80 transition hover:border-white/20 hover:bg-white/[0.06] hover:text-white"
              >
                Compare packages →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 md:hidden">
      <a
        href="/services"
        class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.03] px-5 py-3 text-sm text-white/80 transition hover:border-white/20 hover:bg-white/[0.06] hover:text-white"
      >
        Compare packages
      </a>
    </div>
  </div>
</section>