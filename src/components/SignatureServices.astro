---
import { Image } from "astro:assets";
import fTypeExterior from "../assets/f-type-exterior.jpg";
import gt3Front from "../assets/gt3-hero.jpg";
import gt3Interior from "../assets/gt3-interior.jpg";
import gt3engine from "../assets/gt3-engine.wbp" ;
const services = [
  {
    eyebrow: "Maintenance",
    title: "Maintenance Detail",
    desc: "For already well-kept vehicles that need consistent upkeep with a clean, polished finish.",
    image: gt3engine,
    alt: "Factory Reset Detail maintenance exterior finish",
    service: "maintenance",
  },
  {
    eyebrow: "Most Popular",
    title: "Signature Detail",
    desc: "A deeper, more complete service designed to leave the vehicle feeling professionally finished.",
    image: gt3Front,
    alt: "Factory Reset Detail signature exterior detail",
    service: "signature",
  },
  {
    eyebrow: "Complete Reset",
    title: "Factory Reset Detail",
    desc: "The most comprehensive reset short of correction work, inside and out.",
    image: gt3Interior,
    alt: "Factory Reset Detail deep-cleaned interior",
    service: "reset",
  },
];
---

<section class="bg-neutral-950 text-white">
  <div class="mx-auto max-w-7xl px-6 py-14 lg:px-10 lg:py-18">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/50">Services</p>
        <h2 class="mt-3 text-3xl font-semibold leading-tight md:text-4xl">
          Signature services, executed with restraint.
        </h2>
        <p class="mt-4 max-w-2xl text-white/70">
          Focused packages designed for paint, wheels, glass, and interior—delivered at your home in Collin County.
        </p>
      </div>

      <a
        href="/services"
        class="hidden rounded-full border border-white/12 px-5 py-3 text-sm text-white/78 transition hover:border-white/24 hover:text-white md:inline-flex"
      >
        View all
      </a>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {services.map((service) => (
        <article class="overflow-hidden rounded-[1.75rem] border border-white/10 bg-white/[0.03]">
          <div class="aspect-[4/3] overflow-hidden">
            <Image
              src={service.image}
              alt={service.alt}
              class="h-full w-full object-cover"
            />
          </div>

          <div class="p-6">
            <p class="text-xs uppercase tracking-[0.24em] text-white/45">
              {service.eyebrow}
            </p>

            <h3 class="mt-3 text-2xl font-semibold">
              {service.title}
            </h3>

            <p class="mt-3 text-sm leading-relaxed text-white/68">
              {service.desc}
            </p>

            <div class="mt-6 flex gap-3">
              <a
                href={`/book?service=${service.service}`}
                class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-medium text-neutral-950 transition hover:opacity-90"
              >
                Book now
              </a>

              <a
                href={`/services?focus=${service.service}`}
                class="inline-flex items-center justify-center rounded-full border border-white/12 px-5 py-3 text-sm text-white/80 transition hover:border-white/24 hover:text-white"
              >
                Explore service →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 md:hidden">
      <a
        href="/services"
        class="inline-flex rounded-full border border-white/12 px-5 py-3 text-sm text-white/78 transition hover:border-white/24 hover:text-white"
      >
        View all
      </a>
    </div>
  </div>
</section>
