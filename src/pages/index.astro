---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import SignatureServices from "../components/SignatureServices.astro";

const heroImages = [
  {
    src: "/img/FRD-Hero/F-Type-Rear-Quarter-4_3(squooshed).jpg",
    alt: "Factory Reset Detail Jaguar exterior finish",
  },
  {
    src: "/img/FRD-Hero/Jaguar-Interior-4_3(squooshed).jpg",
    alt: "Factory Reset Detail Jaguar interior detail",
  },
  {
    src: "/img/FRD-Hero/porsche-gt3-front.webp",
    alt: "Factory Reset Detail Porsche GT3 exterior finish",
  },
  {
    src: "/img/FRD-Hero/GT3-Trunk-4_3(squooshed).jpg",
    alt: "Factory Reset Detail Porsche GT3 trunk detail",
  },
];
---

<Layout>
  <Hero>
    <div
      class="hero-slideshow group relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.03]"
      data-hero-slideshow
    >
      <div class="relative aspect-[16/11] w-full">
        {heroImages.map((image, index) => (
          <img
            src={image.src}
            alt={image.alt}
            class={`hero-slide absolute inset-0 h-full w-full object-cover ${
              index === 0 ? "opacity-100" : "opacity-0"
            }`}
            data-hero-slide
          />
        ))}

        <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-black/38 via-black/8 to-transparent"></div>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/22 to-transparent"></div>
      </div>

      <div class="absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 gap-2">
        {heroImages.map((_, index) => (
          <button
            type="button"
            class={`hero-dot h-2 rounded-full transition-all duration-300 ${
              index === 0 ? "w-8 bg-white" : "w-2 bg-white/30 hover:bg-white/70"
            }`}
            aria-label={`Show hero image ${index + 1}`}
            data-hero-dot
          />
        ))}
      </div>
    </div>
  </Hero>

  <section class="bg-neutral-950 text-white">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-10 lg:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-white/45">Craftsmanship</p>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-4xl">
        Premium detailing, delivered with restraint.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-white/68 md:text-lg">
        A professional, mobile service designed to save you time, protect your materials,
        and deliver a calm, finished result without unnecessary upsells or overdone dressing.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
        <h3 class="text-lg font-medium text-white">Premium results</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/68">
          Clean, polished, and professionally finished—without greasy surfaces,
          artificial shine, or rushed shortcuts.
        </p>
      </article>

      <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
        <h3 class="text-lg font-medium text-white">Convenience built in</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/68">
          Service performed at your home or workplace with a process that feels simple,
          clear, and easy from first message to final walkthrough.
        </p>
      </article>

      <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
        <h3 class="text-lg font-medium text-white">Professional care</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/68">
          Thoughtful methods, material-safe products, and clear recommendations tailored
          to the vehicle instead of one-size-fits-all package talk.
        </p>
      </article>
    </div>
  </div>
</section>

  <SignatureServices />
</Layout>

<script is:inline>
(() => {
  const slideshow = document.querySelector("[data-hero-slideshow]");
  if (!slideshow) return;

  const slides = [...slideshow.querySelectorAll("[data-hero-slide]")];
  const dots = [...slideshow.querySelectorAll("[data-hero-dot]")];

  if (!slides.length || !dots.length) return;

  let current = 0;
  let intervalId;

  const setActive = (index) => {
    current = index;

    slides.forEach((slide, i) => {
      slide.classList.toggle("opacity-100", i === index);
      slide.classList.toggle("opacity-0", i !== index);
    });

    dots.forEach((dot, i) => {
      dot.classList.toggle("w-8", i === index);
      dot.classList.toggle("bg-white", i === index);
      dot.classList.toggle("w-2", i !== index);
      dot.classList.toggle("bg-white/35", i !== index);
      dot.classList.toggle("hover:bg-white/55", i !== index);
    });
  };

  const stop = () => {
    if (intervalId) {
      window.clearInterval(intervalId);
      intervalId = null;
    }
  };

  const start = () => {
    stop();
    intervalId = window.setInterval(() => {
      const next = (current + 1) % slides.length;
      setActive(next);
    }, 5000);
  };

  dots.forEach((dot, index) => {
    dot.addEventListener("click", () => {
      setActive(index);
      start();
    });
  });

  slideshow.addEventListener("mouseenter", stop);
  slideshow.addEventListener("mouseleave", start);

  setActive(0);
  start();
})();
</script>

<style>
.hero-slide {
  transition: opacity 900ms ease;
  will-change: opacity;
}
</style>