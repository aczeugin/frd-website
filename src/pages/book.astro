---
import Layout from "../layouts/Layout.astro";

const calOrigin = import.meta.env.PUBLIC_CAL_ORIGIN ?? "https://cal.com";
---

<Layout
  title="Book Mobile Detailing in McKinney, TX | Factory Reset Detail"
  description="Book premium mobile detailing in McKinney, TX. Interior and exterior detailing at your home or workplace."
>
  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:px-10 lg:py-16">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.35em] text-white/50">Booking</p>

        <h1 class="mt-3 text-4xl font-semibold leading-tight md:text-5xl">
          Book your detail.
        </h1>

        <p class="mt-4 max-w-2xl text-base text-white/70 md:text-lg">
          Reserve a time below. After booking, you'll receive a text with a link
          to photograph your vehicle so we can confirm condition before arrival.
        </p>

        <div class="mt-6 inline-flex flex-wrap items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/80">
          <span class="font-medium text-white">Currently viewing:</span>
          <span id="selected-service-label">Signature Detail</span>
          <span class="hidden text-white/30 sm:inline">•</span>
          <a href="/services" class="text-white/60 underline underline-offset-2 hover:text-white/90">Compare all services</a>
        </div>

        <div class="mt-6 flex flex-wrap gap-2">
          <a
            id="service-pill-maintenance"
            href="/book?service=maintenance"
            class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/75 transition hover:border-white/20 hover:bg-white/10"
          >
            Maintenance
          </a>

          <a
            id="service-pill-signature"
            href="/book?service=signature"
            class="inline-flex items-center rounded-full border border-white bg-white px-4 py-2 text-sm text-neutral-950 transition"
          >
            Signature
          </a>

          <a
            id="service-pill-reset"
            href="/book?service=reset"
            class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/75 transition hover:border-white/20 hover:bg-white/10"
          >
            Factory Reset
          </a>
        </div>

        <p id="selected-service-blurb" class="mt-4 max-w-2xl text-sm text-white/55">
          Best for clients wanting a deeper, more complete detail with stronger interior and wheel attention.
        </p>

        <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 px-5 py-4">
          <p class="mb-3 text-xs uppercase tracking-[0.35em] text-white/40">Starting Pricing</p>
          <div class="flex flex-wrap gap-x-8 gap-y-2">
            <div class="flex items-baseline gap-2">
              <span class="text-sm text-white/55">Coupe</span>
              <span id="price-coupe" class="text-sm font-semibold text-white"></span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-sm text-white/55">Sedan</span>
              <span id="price-sedan" class="text-sm font-semibold text-white"></span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-sm text-white/55">SUV / Truck</span>
              <span id="price-suv" class="text-sm font-semibold text-white"></span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-sm text-white/55">Minivan / Suburban</span>
              <span id="price-minivan" class="text-sm font-semibold text-white"></span>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-[1.25rem] border border-white/10 bg-white/[0.03] p-5">
          <p class="text-xs uppercase tracking-[0.28em] text-white/40">01</p>
          <h3 class="mt-2 text-sm font-medium text-white">Choose a package</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/58">
            Pick the level that fits your vehicle's condition.
            <a href="/services" class="text-white/75 underline underline-offset-2 hover:text-white">See what's included</a>
            if you're not sure.
          </p>
        </div>

        <div class="rounded-[1.25rem] border border-white/10 bg-white/[0.03] p-5">
          <p class="text-xs uppercase tracking-[0.28em] text-white/40">02</p>
          <h3 class="mt-2 text-sm font-medium text-white">Pick a time</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/58">
            Select a date and window below. You'll receive a confirmation and a
            photo request to verify condition before arrival.
          </p>
        </div>

        <div class="rounded-[1.25rem] border border-white/10 bg-white/[0.03] p-5">
          <p class="text-xs uppercase tracking-[0.28em] text-white/40">03</p>
          <h3 class="mt-2 text-sm font-medium text-white">We come to you</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/58">
            Service at your home, workplace, or apartment. Final pricing is
            confirmed on-site before work begins—never a surprise.
          </p>
        </div>
      </div>

      <p class="mt-4 text-xs text-white/38">
        Serving McKinney, Allen, Frisco, Plano, Prosper, Lucas, and surrounding Collin County areas.
      </p>

      <div class="mt-10 overflow-hidden rounded-[28px] border border-white/10 bg-neutral-900/40 backdrop-blur">
        <div id="cal-booker" class="min-h-[780px]"></div>
      </div>

      <!-- Confirmation banner — hidden until Cal fires bookingSuccessfulV2 -->
      <div
        id="booking-confirmation"
        class="confirmation-banner mt-10 overflow-hidden rounded-[28px] border border-white/10 bg-white/5"
        aria-hidden="true"
      >
        <div class="p-6 lg:p-8">
          <div class="flex items-start gap-4">
            <!-- Checkmark icon -->
            <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/8">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>

            <div class="min-w-0">
              <p class="text-xs uppercase tracking-[0.35em] text-white/50">You're booked</p>
              <h2 class="mt-2 text-xl font-semibold leading-snug md:text-2xl">
                Check your phone in a moment.
              </h2>
              <p class="mt-3 max-w-xl text-base text-white/70 leading-relaxed">
                You'll receive a text shortly with a link to photograph your vehicle.
                Photos let us confirm condition and get you an accurate quote before
                we arrive — but they're never required.
              </p>
              <p class="mt-3 text-sm text-white/45">
                Skipping photos? No problem — your detailer will assess the vehicle
                on arrival and confirm pricing before starting.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .confirmation-banner {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    transition:
      max-height 600ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 500ms ease,
      margin-top 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .confirmation-banner.visible {
    max-height: 400px;
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script is:inline define:vars={{ calOrigin }}>
  (function () {
    const services = {
      maintenance: {
        label: "Maintenance Detail",
        slug: "factoryresetdetail/maintenance-detail",
        blurb:
          "Best for already well-kept vehicles that need consistent upkeep and preferred recurring pricing.",
        pricing: { coupe: "$75", sedan: "$100", suv: "$125", minivan: "$150" },
      },
      signature: {
        label: "Signature Detail",
        slug: "factoryresetdetail/signature-detail",
        blurb:
          "Best for clients wanting a deeper, more complete detail with stronger interior and wheel attention.",
        pricing: { coupe: "$125", sedan: "$150", suv: "$175", minivan: "$200" },
      },
      reset: {
        label: "Factory Reset Detail",
        slug: "factoryresetdetail/factory-reset-detail",
        blurb:
          "Best for the most comprehensive reset short of correction work, inside and out.",
        pricing: { coupe: "$175", sedan: "$200", suv: "$250", minivan: "$275" },
      },
    };

    const defaultService = "signature";
    const params = new URLSearchParams(window.location.search);
    const serviceParam = params.get("service");
    const activeService = services[serviceParam] ? serviceParam : defaultService;
    const selected = services[activeService];

    const labelEl = document.getElementById("selected-service-label");
    const blurbEl = document.getElementById("selected-service-blurb");

    if (labelEl) labelEl.textContent = selected.label;
    if (blurbEl) blurbEl.textContent = selected.blurb;

    const priceEls = {
      coupe: document.getElementById("price-coupe"),
      sedan: document.getElementById("price-sedan"),
      suv: document.getElementById("price-suv"),
      minivan: document.getElementById("price-minivan"),
    };
    Object.entries(priceEls).forEach(([key, el]) => {
      if (el) el.textContent = selected.pricing[key];
    });

    const pillIds = {
      maintenance: "service-pill-maintenance",
      signature: "service-pill-signature",
      reset: "service-pill-reset",
    };

    Object.entries(pillIds).forEach(([key, id]) => {
      const el = document.getElementById(id);
      if (!el) return;

      if (key === activeService) {
        el.className =
          "inline-flex items-center rounded-full border border-white bg-white px-4 py-2 text-sm text-neutral-950 transition";
      } else {
        el.className =
          "inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/75 transition hover:border-white/20 hover:bg-white/10";
      }
    });

    window.showConfirmation = function () {
      const banner = document.getElementById("booking-confirmation");
      if (!banner) return;

      banner.removeAttribute("aria-hidden");
      banner.classList.add("visible");

      // Scroll to banner after transition starts
      setTimeout(() => {
        banner.scrollIntoView({ behavior: "smooth", block: "start" });
      }, 100);
    }

    function bootCal() {
      if (!window.Cal) return;

      const booker = document.getElementById("cal-booker");
      if (booker) booker.innerHTML = "";

      window.Cal("init", { origin: calOrigin });

      window.Cal("inline", {
        elementOrSelector: "#cal-booker",
        calLink: selected.slug,
        config: {
          layout: "month_view",
          "metadata[selectedService]": selected.label,
        },
      });

      window.Cal("ui", {
        styles: {
          body: {
            background: "#0a0a0a",
          },
        },
      });

      window.Cal("on", {
        action: "bookingSuccessfulV2",
        callback: function () {
          if (typeof gtag === 'function') {
            gtag('event', 'booking_complete', {
              event_category: 'engagement',
              event_label: selected.label,
            });
          }
          window.location.href = '/thank-you';
        },
      });
    }

    if (window.Cal) {
      bootCal();
      return;
    }

    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal =
        C.Cal ||
        function () {
          let cal = C.Cal;
          let ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            let s = d.createElement("script");
            s.src = A;
            s.async = true;
            d.head.appendChild(s);
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () { p(api, arguments); };
            const namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === "string") {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
            } else {
              p(cal, ar);
            }
            return;
          }
          p(cal, ar);
        };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    bootCal();
  })();
</script>
