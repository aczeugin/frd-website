---
import Layout from "../layouts/Layout.astro";

const calLink = "YOUR_CAL_LINK";
const uploadFormUrl = "YOUR_UPLOAD_FORM_URL";
const service = Astro.url.searchParams.get("service") ?? "";
const serviceLabelMap = {
  maintenance: "Maintenance Detail",
  signature: "Signature Detail",
  reset: "Factory Reset Detail",
};

const selectedService =
  serviceLabelMap[service as keyof typeof serviceLabelMap] ?? "Detail Appointment";
---

<Layout
  title="Book a Detail | Factory Reset Detail"
  description="Schedule your mobile detailing appointment with Factory Reset Detail."
>
  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-6xl px-6 py-14 lg:px-10 lg:py-20">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.32em] text-white/55">
          Booking
        </p>

        <h1 class="mt-4 text-4xl font-semibold leading-tight md:text-5xl">
          Book your detail.
        </h1>

        <p class="mt-5 text-base leading-relaxed text-white/72 md:text-lg">
          Choose a time that works for you, then send a few vehicle photos so I can confirm
          condition, service fit, and any add-ons before arrival.
        </p>

        <div class="mt-6 flex flex-wrap gap-3 text-sm text-white/70">
          <span class="rounded-full border border-white/12 bg-white/5 px-4 py-2">
            Selected service: {selectedService}
          </span>
          <span class="rounded-full border border-white/12 bg-white/5 px-4 py-2">
            Mobile service in McKinney + surrounding areas
          </span>
        </div>
      </div>

      <div class="mt-10 grid gap-8 lg:grid-cols-[1.3fr_0.7fr]">
        <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-3 md:p-4">
          <div class="overflow-hidden rounded-[1.4rem] border border-white/10 bg-black">
            <iframe
              src={`${calLink}${service ? `?service=${service}` : ""}`}
              title="Book with Factory Reset Detail"
              class="h-[860px] w-full"
              loading="lazy"
            />
          </div>
        </div>

        <aside class="space-y-5">
          <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
            <p class="text-xs uppercase tracking-[0.28em] text-white/50">
              Step 2
            </p>
            <h2 class="mt-3 text-2xl font-semibold">
              Upload photos
            </h2>
            <p class="mt-3 text-sm leading-relaxed text-white/70">
              After booking, upload a few current photos of the exterior, interior, wheels,
              and any problem areas. That lets me confirm condition and recommend the right level
              of service before the appointment.
            </p>

            <a
              href={uploadFormUrl}
              target="_blank"
              rel="noreferrer"
              class="mt-5 inline-flex w-full items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-medium text-neutral-950 transition hover:opacity-90"
            >
              Upload vehicle photos
            </a>

            <p class="mt-3 text-xs text-white/45">
              Fallback: you can still text photos if needed, but upload is preferred for cleaner intake.
            </p>
          </div>

          <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
            <p class="text-xs uppercase tracking-[0.28em] text-white/50">
              What to include
            </p>

            <ul class="mt-4 space-y-3 text-sm text-white/72">
              <li>Front 3/4 exterior</li>
              <li>Rear 3/4 exterior</li>
              <li>Driver seat / front cabin</li>
              <li>Rear seats / cargo area</li>
              <li>Wheels / brake dust condition</li>
              <li>Any stains, pet hair, or problem spots</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
