---
import Layout from "../layouts/Layout.astro";

const siteUrl = "https://www.factoryresetdetail.com";

const packages = [
  {
    eyebrow: "Maintenance",
    title: "Maintenance Detail",
    service: "maintenance",
    bestFor: "Best for: clients on a recurring maintenance plan",
    desc:
      "Designed for vehicles that are already well cared for. Most clients choose this service on a recurring plan to keep the vehicle consistently clean while receiving preferred pricing and priority scheduling.",
    bullets: [
      "Safe foam pre-rinse + contact wash (no swirl-inducing shortcuts)",
      "Streak-free exterior dry using premium microfiber",
      "Interior reset of primary surfaces (dash, console, touchpoints)",
      "Vacuum of carpets, seats, and light debris areas",
    ],
    meta: ["Preferred recurring pricing", "Popular with bi-weekly clients"],
  },
  {
    eyebrow: "Full Detail",
    title: "Signature Detail",
    service: "signature",
    bestFor: "Best for: clients wanting a deeper, more complete detail",
    desc:
      "A deeper, more complete clean with the details that make it feel professionally finished.",
    bullets: [
      "Deep wheel cleaning (faces, barrels, and tires)",
      "Door jambs and hidden areas fully cleaned",
      "Interior crevices, vents, and touchpoints detailed",
      "Protective spray sealant applied for gloss and hydrophobic behavior",
    ],
    meta: ["Most popular", "Balanced depth and upkeep"],
  },
  {
    eyebrow: "Complete Reset",
    title: "Factory Reset Detail",
    service: "reset",
    bestFor: "Best for: the most complete reset without stepping into paint correction",
    desc:
      "Comprehensive, top-to-bottom detailing designed to make the vehicle feel new again—inside, outside, and in the details.",
    bullets: [
      "Comprehensive interior reset (including under seats and rails)",
      "Advanced wheel + tire cleaning with full attention to detail",
      "Air-assisted drying to eliminate drips and water marks",
      "Upgraded ceramic spray protection for long-lasting finish",
    ],
    meta: ["Flagship service", "Most comprehensive"],
  },
];

const addons = [
  {
    title: "Headlight restoration",
    desc: "Restores clarity for improved output and a cleaner front-end finish.",
  },
  {
    title: "Pet hair removal",
    desc: "Time-based add-on depending on severity and material type.",
  },
  {
    title: "Biohazard remediation",
    desc: "For bodily fluids (vomit, urine, etc.). Quoted based on scope and safety needs.",
  },
  {
    title: "Carpet shampoo",
    desc: "Deep cleaning for set-in grime and traffic areas. Condition-based pricing.",
  },
  {
    title: "Stain removal",
    desc: "Targeted treatment for visible stains—results vary by material and dwell time.",
  },
  {
    title: "Trim restoration",
    desc: "Revives interior and exterior trim for a darker, more even finish without greasy residue.",
  },
  {
    title: "Advanced Hydrophobic Protection",
    desc: "Upgraded protection using a higher-performance sealant for stronger water behavior and easier maintenance.",
  },
  {
    title: "Clay + Decontamination",
    desc: "Removes bonded contaminants for a smoother finish—recommended before correction or longer-term protection.",
  },
];

const faqs = [
  {
    q: "How long does a detail take?",
    a: "Most services run 2–4 hours, with heavier-condition vehicles or add-ons taking longer depending on size and condition.",
  },
  {
    q: "Do you bring your own water and power?",
    a: "I arrive fully equipped with the tools needed, including a water hose and extension cable. I’ll just need access to a standard outdoor spigot and outlet to perform the service.",
  },
  {
    q: "Is this safe for new, luxury, or ceramic-coated vehicles?",
    a: "Absolutely. Methods and products are selected to preserve materials and existing protection with paint-safe technique.",
  },
  {
    q: "Do you offer pricing over text?",
    a: "I can usually provide a range, but final pricing depends on condition. Photos help me recommend the right level of service without guesswork.",
  },
  {
    q: "What’s the difference between the Maintenance Detail and a full detail?",
    a: "The Maintenance Detail is for vehicles already in good condition—it keeps things consistent between visits at preferred pricing. The Signature and Factory Reset Details go deeper: more time on wheels, jambs, crevices, and interior surfaces. If it’s your first service or the vehicle hasn’t been detailed in a while, I’ll usually recommend starting with a full detail.",
  },
  {
    q: "Do you offer interior-only detailing?",
    a: "Interior-focused services are available depending on condition and scope. If the cabin is your main priority, let me know when you reach out and I’ll recommend the right approach based on what you describe.",
  },
  {
    q: "Can you service my vehicle at an apartment complex or my workplace?",
    a: "Yes. I work around your schedule and location—apartment parking lots, office complexes, or wherever the vehicle is parked. I just need access to a standard outdoor water spigot and outlet nearby. If access is uncertain, send me the address and I’ll confirm.",
  },
  {
    q: "Do you detail SUVs and trucks?",
    a: "Yes—SUVs, trucks, and larger vehicles are serviced regularly. Pricing reflects the additional time and surface area. Send me the make and approximate condition and I’ll give you an accurate quote upfront.",
  },
  {
    q: "What should I expect to pay?",
    a: "Most services range from $150–$400+ depending on vehicle size, condition, and the level of service. I don’t publish flat rates because condition matters—a clean daily driver and a neglected family SUV are very different jobs. Photos help me quote accurately without surprises.",
  },
];

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "url": `${siteUrl}/services`,
  "name": "Mobile Car Detailing Services FAQ — Factory Reset Detail, McKinney TX",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a,
    },
  })),
};
---

<Layout
  title="Mobile Detailing Services in McKinney, TX | Factory Reset Detail"
  description="Explore mobile detailing services in McKinney, TX including interior, exterior, and full-service detailing for cars, SUVs, and trucks."
  pageSchema={pageSchema}
>
  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:px-10 lg:py-16">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.32em] text-white/50">Mobile Detailing · McKinney, TX</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight md:text-5xl">
          Mobile detailing services in McKinney, Texas.
        </h1>
        <p class="mt-5 text-base leading-relaxed text-white/70 md:text-lg">
          A fully mobile service based in McKinney, TX — bringing professional interior and exterior
          detailing directly to your home, workplace, or wherever the vehicle is parked. Serving McKinney,
          Allen, Frisco, Plano, Prosper, and the surrounding Collin County area. Every service is finished
          to a high standard: clean without being greasy, refined without being overdone.
        </p>
      </div>

      <div class="mt-8 flex flex-wrap gap-3 text-sm text-white/65">
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2">Paint-safe methods</span>
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2">Material-correct finishes</span>
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2">Clear recommendations</span>
      </div>

      <div class="mt-10 md:hidden">
        <div
          class="mobile-service-track no-scrollbar flex snap-x snap-mandatory gap-4 overflow-x-auto pb-4"
          data-service-track
        >
          {packages.map((p, index) => (
            <article
              class={`service-slide min-w-[86%] snap-center rounded-[1.75rem] border p-6 transition ${
                index === 0
                  ? "border-white/22 bg-white/[0.06]"
                  : "border-white/10 bg-white/[0.03]"
              }`}
              data-service-slide
            >
              <p class="text-xs uppercase tracking-[0.26em] text-white/45">{p.eyebrow}</p>

              <h2 class="mt-3 text-2xl font-semibold">{p.title}</h2>

              {p.title === "Signature Detail" && (
                <div class="mt-3 inline-flex rounded-full border border-white/12 bg-white/8 px-3 py-1 text-[11px] uppercase tracking-[0.22em] text-white/75">
                  Most Popular
                </div>
              )}

              <p class="mt-4 text-sm text-white/58">{p.bestFor}</p>
              <p class="mt-4 text-sm leading-relaxed text-white/72">{p.desc}</p>

              <ul class="mt-5 space-y-3 text-sm text-white/78">
                {p.bullets.map((b) => <li>• {b}</li>)}
              </ul>

              <div class="mt-5 flex flex-wrap gap-2">
                {p.meta.map((m) => (
                  <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-white/58">
                    {m}
                  </span>
                ))}
              </div>

              <div class="mt-6 flex gap-3">
                <a
                  href={`/book?service=${p.service}`}
                  class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-medium text-neutral-950"
                  data-track="book_click"
                  data-track-label={`Services (mobile) — ${p.title}`}
                >
                  Reserve
                </a>
                <a
                  href="/services#contact"
                  class="inline-flex items-center justify-center rounded-full border border-white/12 px-5 py-3 text-sm text-white/80"
                >
                  Get a recommendation
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-4 flex justify-center gap-2" data-service-dots>
          {packages.map((_, index) => (
            <button
              type="button"
              class={`h-2.5 rounded-full transition ${
                index === 0 ? "w-8 bg-white" : "w-2.5 bg-white/30"
              }`}
              aria-label={`Go to service ${index + 1}`}
              data-service-dot
            />
          ))}
        </div>

        <p class="mt-4 text-center text-xs uppercase tracking-[0.24em] text-white/38">
          Swipe to compare packages
        </p>
      </div>

      <div class="mt-10 hidden gap-6 md:grid md:grid-cols-3">
        {packages.map((p) => (
          <article class="rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-6">
            <p class="text-xs uppercase tracking-[0.26em] text-white/45">{p.eyebrow}</p>
            <h2 class="mt-3 text-2xl font-semibold">{p.title}</h2>

            {p.title === "Signature Detail" && (
              <div class="mt-3 inline-flex rounded-full border border-white/12 bg-white/8 px-3 py-1 text-[11px] uppercase tracking-[0.22em] text-white/75">
                Most Popular
              </div>
            )}

            <p class="mt-4 text-sm text-white/58">{p.bestFor}</p>
            <p class="mt-4 text-sm leading-relaxed text-white/72">{p.desc}</p>

            <ul class="mt-5 space-y-3 text-sm text-white/78">
              {p.bullets.map((b) => <li>• {b}</li>)}
            </ul>

            <div class="mt-5 flex flex-wrap gap-2">
              {p.meta.map((m) => (
                <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-white/58">
                  {m}
                </span>
              ))}
            </div>

            <div class="mt-6 flex gap-3">
              <a
                href={`/book?service=${p.service}`}
                class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-medium text-neutral-950"
                data-track="book_click"
                data-track-label={`Services (desktop) — ${p.title}`}
              >
                Reserve
              </a>
              <a
                href="/services#contact"
                class="inline-flex items-center justify-center rounded-full border border-white/12 px-5 py-3 text-sm text-white/80"
              >
                Get a recommendation
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-10 lg:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs uppercase tracking-[0.28em] text-white/45">What's included</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-4xl">
          Every service. Thoughtfully executed.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-white/68">
          Each detail covers interior and exterior work with methods selected to protect the vehicle—not just clean it.
        </p>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Exterior wash</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Safe foam pre-rinse and contact wash using paint-safe technique — no swirl-inducing shortcuts, no drive-through pressure.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Interior detailing</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Vacuumed, wiped, and treated throughout — dash, console, vents, door panels, and touchpoints. Clean without fragrance, residue, or plastic gloss.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Wheels and tires</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Faces, barrels, and tires cleaned with appropriate product for each surface. Brake dust and road film removed properly — not masked.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Paint-safe drying</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Premium microfiber and air-assisted drying to eliminate water spots and drips — no drag, no abrasion on the clear coat.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Protection options</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Spray sealant or ceramic spray protection applied for hydrophobic behavior and lasting gloss — chosen for longevity, not showroom theater.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-10 lg:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs uppercase tracking-[0.28em] text-white/45">Who this is for</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-4xl">
          Built for every vehicle, scaled to its needs.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-white/68">
          Whether it's a daily commuter or a garage-kept enthusiast car, the approach adapts to the vehicle and its condition.
        </p>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Daily drivers</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Consistent upkeep without the hassle. A recurring maintenance plan keeps your daily looking sharp between deeper services.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Enthusiast cars</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Paint-safe methods, careful product selection, and attention to detail that matches how much the vehicle matters to you.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Luxury vehicles</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Material-correct technique on premium surfaces — leather, alcantara, carbon, and coated paint treated with the right products and the right amount of restraint.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">SUVs</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            More surface area, more interior volume — priced and paced accordingly. Full attention to third-row areas, cargo space, and larger wheel faces.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Trucks</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Bed areas, running boards, and heavily used interiors handled with the same care as the rest. Work trucks and weekend trucks both welcome.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h3 class="text-base font-medium text-white">Family vehicles</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">
            Pet hair, car seats, crumbs, and lived-in grime — this is what the Factory Reset service is designed for. Start fresh and maintain from there.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-10 lg:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs uppercase tracking-[0.28em] text-white/45">Service Area</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-4xl">
          Areas we commonly serve
        </h2>
        <p class="mt-4 text-base leading-relaxed text-white/68">
          Based in McKinney — mobile service available throughout Collin County and nearby communities.
        </p>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {["McKinney", "Allen", "Frisco", "Plano", "Prosper", "Lucas", "Fairview", "Melissa", "Anna", "Celina"].map((city) => (
          <span class="rounded-full border border-white/10 bg-white/[0.03] px-5 py-2.5 text-sm text-white/78">
            {city}
          </span>
        ))}
      </div>

      <p class="mt-6 text-center text-xs text-white/40">
        Availability depends on schedule and travel distance. Reach out to confirm your location.
      </p>
    </div>
  </section>

  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-6 lg:px-10 lg:py-8">
      <div class="rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-7">
        <p class="text-xs uppercase tracking-[0.28em] text-white/45">Custom</p>
        <h3 class="mt-3 text-2xl font-semibold">Condition-based recommendations</h3>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-white/70">
          Not every vehicle fits neatly into a package. If you’re unsure, send a few photos and I’ll recommend
          the right level of service based on condition—no upsells, just clarity.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-6 lg:px-10 lg:py-8">
      <div class="rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-7">
        <p class="text-xs uppercase tracking-[0.28em] text-white/45">Ceramic Coatings</p>
        <h3 class="mt-3 text-2xl font-semibold">Coming Soon</h3>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-white/70">
          Ceramic coatings are planned for this year. For the best visual result and proper bonding,
          I strongly recommend decontamination and paint refinement beforehand—even on newer vehicles.
          Final prep is always based on paint condition, finish expectations, and the protection package selected.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:px-10">
      <p class="text-xs uppercase tracking-[0.28em] text-white/45">Optional Upgrades</p>
      <h3 class="mt-3 text-3xl font-semibold">Optional upgrades, added when they make sense.</h3>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-white/70">
        Additional services are recommended based on condition, material, and time required—not pushed by default.
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {addons.map((a) => (
          <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-5">
            <h4 class="text-lg font-medium">{a.title}</h4>
            <p class="mt-3 text-sm leading-relaxed text-white/68">{a.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

<section id="results" class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:px-10">
      <p class="text-xs uppercase tracking-[0.28em] text-white/45">Results</p>
      <h3 class="mt-3 text-3xl font-semibold">Outcomes you can see—and maintain</h3>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h4 class="text-xl font-medium">Clarity without harshness</h4>
          <p class="mt-3 text-sm leading-relaxed text-white/68">
            Refinement that respects clear coat and avoids an overworked look.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h4 class="text-xl font-medium">Factory-calm interiors</h4>
          <p class="mt-3 text-sm leading-relaxed text-white/68">
            A clean, dry finish—no greasy shine, no heavy fragrance, no residue.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <h4 class="text-xl font-medium">Protection that makes life easier</h4>
          <p class="mt-3 text-sm leading-relaxed text-white/68">
            Protectants selected for longevity and maintenance, not hype.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section id="process" class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:px-10">
      <p class="text-xs uppercase tracking-[0.28em] text-white/45">Process</p>
      <h3 class="mt-3 text-3xl font-semibold">A calm, methodical approach</h3>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <p class="text-sm text-white/45">01</p>
          <h4 class="mt-3 text-xl font-medium">Assessment</h4>
          <p class="mt-3 text-sm leading-relaxed text-white/68">
            We evaluate condition, surfaces, and priorities before choosing the right methods.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <p class="text-sm text-white/45">02</p>
          <h4 class="mt-3 text-xl font-medium">Material-correct execution</h4>
          <p class="mt-3 text-sm leading-relaxed text-white/68">
            Paint-safe technique, controlled product use, and deliberate finishing—no rushed shortcuts.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6">
          <p class="text-sm text-white/45">03</p>
          <h4 class="mt-3 text-xl font-medium">Final inspection</h4>
          <p class="mt-3 text-sm leading-relaxed text-white/68">
            We check details under proper lighting and leave clear guidance for care.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section id="faq" class="bg-neutral-950 text-white">
    <div class="mx-auto max-w-5xl px-6 py-12 lg:px-10">
      <p class="text-xs uppercase tracking-[0.28em] text-white/45">FAQ</p>
      <h3 class="mt-3 text-3xl font-semibold">Quick answers</h3>

      <div class="mt-8 space-y-4">
        {faqs.map((f) => (
          <details class="rounded-[1.25rem] border border-white/10 bg-white/[0.03] p-5">
            <summary class="cursor-pointer list-none text-base font-medium text-white">
              {f.q}
