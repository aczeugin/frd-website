  <div id="skip-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-6">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="skip-backdrop"></div>
    <div class="relative w-full max-w-sm rounded-[24px] border border-white/10 bg-neutral-900 p-7 shadow-2xl">
      <p class="text-xs uppercase tracking-[0.3em] text-white/45">No problem</p>
      <h2 class="mt-3 text-xl font-semibold leading-snug">
        We'll sort the quote on arrival.
      </h2>
      <p class="mt-3 text-sm text-white/65 leading-relaxed">
        Your appointment on <strong class="text-white/90" id="modal-date">{bookingDate}</strong> is confirmed.
        Your detailer will assess the vehicle's condition on arrival and walk you through
        pricing before any work begins — no surprises.
      </p>
      <div class="mt-6 flex flex-col gap-3">
        <button
          id="skip-confirm-btn"
          type="button"
          class="w-full inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-medium text-neutral-950 transition hover:opacity-90"
        >
          Got it, see you then
        </button>
        <button
          id="skip-cancel-btn"
          type="button"
          class="w-full inline-flex items-center justify-center rounded-full border border-white/10 px-5 py-3 text-sm font-medium text-white/70 transition hover:border-white/20 hover:text-white"
        >
          I'll add photos after all
        </button>
      </div>
    </div>
  </div>

  <!-- All done modal -->
  <div id="success-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-6">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-sm rounded-[24px] border border-white/10 bg-neutral-900 p-7 shadow-2xl text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full border border-white/15 bg-white/8">
        <svg class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h2 class="text-xl font-semibold">Photos received.</h2>
      <p class="mt-3 text-sm text-white/65 leading-relaxed">
        We'll review your vehicle and follow up with a detailed quote shortly.
        See you on <strong class="text-white/90">{bookingDate}</strong>.
      </p>
      <p class="mt-4 text-xs text-white/35">You can close this page.</p>
    </div>
  </div>

</Layout>

<script is:inline define:vars={{ bookingId }}>
(() => {
  const TOTAL_SHOTS = 6;
  const captured = new Array(TOTAL_SHOTS).fill(null); // stores base64 data URLs
  const streams = new Array(TOTAL_SHOTS).fill(null);
  let activeShot = -1;

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const progressBar = document.getElementById('progress-bar');
  const progressLabel = document.getElementById('progress-label');
  const submitBtn = document.getElementById('submit-btn');
  const submitLabel = document.getElementById('submit-label');
  const skipBtn = document.getElementById('skip-btn');
  const skipModal = document.getElementById('skip-modal');
  const skipBackdrop = document.getElementById('skip-backdrop');
  const skipConfirmBtn = document.getElementById('skip-confirm-btn');
  const skipCancelBtn = document.getElementById('skip-cancel-btn');
  const successModal = document.getElementById('success-modal');

  // ── Progress ──────────────────────────────────────────────────────────────
  function updateProgress() {
    const done = captured.filter(Boolean).length;
    const pct = (done / TOTAL_SHOTS) * 100;
    progressBar.style.width = pct + '%';
    progressLabel.textContent = done + ' of ' + TOTAL_SHOTS + ' complete';

    if (done === TOTAL_SHOTS) {
      submitBtn.disabled = false;
      submitLabel.textContent = 'Submit photos';
    } else {
      submitBtn.disabled = true;
      submitLabel.textContent = 'Complete all 6 shots to submit';
    }
  }

  // ── Card open/close ───────────────────────────────────────────────────────
  function openShot(index) {
    // Close previously active shot
    if (activeShot !== -1 && activeShot !== index) {
      closeShot(activeShot);
    }
    activeShot = index;

    const card = document.querySelector('[data-shot="' + index + '"]');
    const panel = card.querySelector('.shot-panel');
    const chevron = card.querySelector('.shot-chevron');

    panel.classList.remove('hidden');
    chevron.style.transform = 'rotate(180deg)';

    // Start camera if not already captured
    if (!captured[index]) {
      startCamera(index);
    }
  }

  function closeShot(index) {
    const card = document.querySelector('[data-shot="' + index + '"]');
    const panel = card.querySelector('.shot-panel');
    const chevron = card.querySelector('.shot-chevron');

    panel.classList.add('hidden');
    chevron.style.transform = '';

    // Stop stream if not captured
    if (!captured[index] && streams[index]) {
      streams[index].getTracks().forEach(t => t.stop());
      streams[index] = null;
    }
  }

  // ── Camera ────────────────────────────────────────────────────────────────
  async function startCamera(index) {
    const card = document.querySelector('[data-shot="' + index + '"]');
    const video = card.querySelector('.shot-video');

    try {
      // Prefer rear camera on mobile
      const stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: { ideal: 'environment' }, width: { ideal: 1920 }, height: { ideal: 1080 } },
        audio: false
      });
      streams[index] = stream;
      video.srcObject = stream;
    } catch (err) {
      console.warn('Camera error:', err);
      setFeedback(index, 'Camera access denied — tap to retry', 'error');
    }
  }

  function setFeedback(index, text, state) {
    const card = document.querySelector('[data-shot="' + index + '"]');
    const dot = card.querySelector('.feedback-dot');
    const textEl = card.querySelector('.feedback-text');

    textEl.textContent = text;

    dot.className = 'feedback-dot h-2 w-2 rounded-full transition-colors duration-300 ';
    if (state === 'good') dot.className += 'bg-emerald-400';
    else if (state === 'error') dot.className += 'bg-red-400';
    else dot.className += 'bg-white/40';
  }

  // ── Capture ───────────────────────────────────────────────────────────────
  function captureShot(index) {
    const card = document.querySelector('[data-shot="' + index + '"]');
    const video = card.querySelector('.shot-video');
    const canvas = card.querySelector('.shot-canvas');
    const captureBtn = card.querySelector('.capture-btn');
    const retakeBtn = card.querySelector('.retake-btn');
    const capturedOverlay = card.querySelector('.captured-overlay');
    const shotStatus = card.querySelector('.shot-status');
    const shotNumber = card.querySelector('.shot-number');
    const shotCheck = card.querySelector('.shot-check');
    const shotBadge = card.querySelector('.shot-badge');
    const guide = card.querySelector('.shot-guide');
    const statusOverlay = card.querySelector('.shot-status-overlay');

    // Draw frame to canvas
    canvas.width = video.videoWidth || 1280;
    canvas.height = video.videoHeight || 720;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
    const dataUrl = canvas.toDataURL('image/jpeg', 0.85);
    captured[index] = dataUrl;

    // Stop stream
    if (streams[index]) {
      streams[index].getTracks().forEach(t => t.stop());
      streams[index] = null;
    }

    // Show captured state
    video.classList.add('hidden');
    capturedOverlay.classList.remove('hidden');
    capturedOverlay.classList.add('flex');
    guide.classList.add('hidden');
    statusOverlay.classList.add('hidden');
    captureBtn.classList.add('hidden');
    retakeBtn.classList.remove('hidden');
    retakeBtn.classList.add('flex');

    // Update card header
    shotStatus.classList.remove('border-white/15', 'bg-white/5');
    shotStatus.classList.add('border-white/25', 'bg-white/10');
    shotNumber.classList.add('hidden');
    shotCheck.classList.remove('hidden');
    shotBadge.classList.remove('hidden');

    updateProgress();

    // Auto-advance to next shot after short delay
    setTimeout(() => {
      if (index < TOTAL_SHOTS - 1) {
        closeShot(index);
        openShot(index + 1);
      }
    }, 800);
  }

  function retakeShot(index) {
    const card = document.querySelector('[data-shot="' + index + '"]');
    const video = card.querySelector('.shot-video');
    const captureBtn = card.querySelector('.capture-btn');
    const retakeBtn = card.querySelector('.retake-btn');
    const capturedOverlay = card.querySelector('.captured-overlay');
    const shotStatus = card.querySelector('.shot-status');
    const shotNumber = card.querySelector('.shot-number');
    const shotCheck = card.querySelector('.shot-check');
    const shotBadge = card.querySelector('.shot-badge');
    const guide = card.querySelector('.shot-guide');
    const statusOverlay = card.querySelector('.shot-status-overlay');

    captured[index] = null;

    video.classList.remove('hidden');
    capturedOverlay.classList.add('hidden');
    capturedOverlay.classList.remove('flex');
    guide.classList.remove('hidden');
    statusOverlay.classList.remove('hidden');
    captureBtn.classList.remove('hidden');
    retakeBtn.classList.add('hidden');
    retakeBtn.classList.remove('flex');

    shotStatus.classList.add('border-white/15', 'bg-white/5');
    shotStatus.classList.remove('border-white/25', 'bg-white/10');
    shotNumber.classList.remove('hidden');
    shotCheck.classList.add('hidden');
    shotBadge.classList.add('hidden');

    updateProgress();
    startCamera(index);
  }

  // ── Event listeners ───────────────────────────────────────────────────────
  document.querySelectorAll('.shot-card').forEach((card) => {
    const index = parseInt(card.dataset.shot);

    card.querySelector('.shot-trigger').addEventListener('click', () => {
      const panel = card.querySelector('.shot-panel');
      if (panel.classList.contains('hidden')) {
        openShot(index);
      } else {
        closeShot(index);
        activeShot = -1;
      }
    });

    card.querySelector('.capture-btn').addEventListener('click', () => captureShot(index));
    card.querySelector('.retake-btn').addEventListener('click', () => retakeShot(index));
  });

  // ── Skip modal ────────────────────────────────────────────────────────────
  skipBtn.addEventListener('click', () => {
    skipModal.classList.remove('hidden');
    skipModal.classList.add('flex');
  });

  skipBackdrop.addEventListener('click', () => {
    skipModal.classList.add('hidden');
    skipModal.classList.remove('flex');
  });

  skipCancelBtn.addEventListener('click', () => {
    skipModal.classList.add('hidden');
    skipModal.classList.remove('flex');
  });

  skipConfirmBtn.addEventListener('click', async () => {
    skipModal.classList.add('hidden');
    skipModal.classList.remove('flex');

    // Notify backend of skip
    try {
      await fetch('/api/submit-photos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bookingId, skipped: true })
      });
    } catch (e) {
      // Silent fail — backend not wired yet
    }

    // Redirect home
    window.location.href = '/';
  });

  // ── Submit ────────────────────────────────────────────────────────────────
  submitBtn.addEventListener('click', async () => {
    submitBtn.disabled = true;
    submitLabel.textContent = 'Sending...';

    try {
      await fetch('/api/submit-photos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bookingId, skipped: false, photos: captured })
      });
    } catch (e) {
      // Silent fail — backend not wired yet
    }

    successModal.classList.remove('hidden');
    successModal.classList.add('flex');
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  updateProgress();
  // Auto-open first shot
  openShot(0);
})();
</script>
