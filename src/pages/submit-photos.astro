---
import Layout from "../layouts/Layout.astro";

const bookingDate = Astro.url.searchParams.get("date") ?? "your appointment";
const bookingName = Astro.url.searchParams.get("name") ?? "";
const bookingId = Astro.url.searchParams.get("id") ?? "";
---

<Layout
  title="Vehicle Photos | Factory Reset Detail"
  description="Submit photos of your vehicle so we can confirm condition and prepare an accurate quote before arrival."
>
  <main class="min-h-screen bg-neutral-950 text-white">
    <section class="mx-auto max-w-2xl px-6 py-12 lg:px-8">

      <!-- Header -->
      <div class="mb-10">
        <p class="text-xs uppercase tracking-[0.35em] text-white/50">Vehicle photos</p>
        <h1 class="mt-3 text-3xl font-semibold leading-tight md:text-4xl">
          Let's get a look at your vehicle.
        </h1>
        <p class="mt-3 text-base text-white/65 leading-relaxed">
          Six quick shots — takes about a minute. Walk around your car and follow the prompts.
          This lets us confirm condition and get you an accurate quote before we arrive.
        </p>

        <!-- Bypass option -->
        <button
          id="skip-btn"
          type="button"
          class="mt-5 text-sm text-white/40 underline underline-offset-4 decoration-white/20 transition hover:text-white/70 hover:decoration-white/50"
        >
          Skip — I'll get a quote on arrival
        </button>
      </div>

      <!-- Progress bar -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs uppercase tracking-[0.28em] text-white/50">Progress</span>
          <span id="progress-label" class="text-xs text-white/50">0 of 6 complete</span>
        </div>
        <div class="h-px bg-white/10 rounded-full overflow-hidden">
          <div
            id="progress-bar"
            class="h-full bg-white rounded-full transition-all duration-500 ease-out"
            style="width: 0%"
          ></div>
        </div>
      </div>

      <!-- Shot cards -->
      <div id="shot-list" class="space-y-3">

        <!-- Shot template — repeated 6x with different content -->
        <div class="shot-card" data-shot="0">
          <div class="rounded-[20px] border border-white/10 bg-white/[0.03] overflow-hidden transition-all duration-300">
            <button type="button" class="shot-trigger w-full text-left p-5 flex items-center gap-4">
              <div class="shot-status flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/5 transition-all duration-300">
                <span class="shot-number text-xs font-medium text-white/60">1</span>
                <svg class="shot-check hidden h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white">Front</p>
                <p class="text-xs text-white/45 mt-0.5 text-left">Stand 8–10 ft back, centered on the grille</p>
              </div>
              <div class="shot-badge hidden shrink-0">
                <span class="text-xs text-emerald-400/80 font-medium">✓ Captured</span>
              </div>
              <svg class="shot-chevron h-4 w-4 text-white/30 transition-transform duration-300 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>

            <div class="shot-panel hidden px-5 pb-5">
              <div class="camera-container relative rounded-2xl overflow-hidden bg-black aspect-[4/3] mb-4">
                <video class="shot-video w-full h-full object-cover" autoplay playsinline muted></video>
                <canvas class="shot-canvas absolute inset-0 w-full h-full hidden"></canvas>

                <!-- Guide overlay -->
                <div class="shot-guide absolute inset-0 flex items-center justify-center pointer-events-none">
                  <div class="border-2 border-white/30 rounded-xl w-[80%] h-[70%] flex items-center justify-center">
                    <span class="text-white/40 text-xs tracking-wider uppercase">Frame vehicle here</span>
                  </div>
                </div>

                <!-- Status overlay -->
                <div class="shot-status-overlay absolute bottom-3 left-3 right-3">
                  <div class="feedback-pill inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-medium backdrop-blur-sm bg-black/50 border border-white/10">
                    <div class="feedback-dot h-2 w-2 rounded-full bg-white/40"></div>
                    <span class="feedback-text">Point camera at front of vehicle</span>
                  </div>
                </div>

                <!-- Captured overlay -->
                <div class="captured-overlay absolute inset-0 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
                  <div class="text-center">
                    <div class="mx-auto mb-2 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 border border-white/20">
                      <svg class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <p class="text-sm font-medium text-white">Shot captured</p>
                  </div>
                </div>
              </div>

              <div class="flex gap-3">
                <button type="button" class="capture-btn flex-1 inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-medium text-neutral-950 transition hover:opacity-90 active:scale-[0.98]">
                  Capture photo
                </button>
                <button type="button" class="retake-btn hidden flex-1 inline-flex items-center justify-center rounded-full border border-white/15 px-5 py-3 text-sm font-medium text-white/80 transition hover:border-white/30 hover:bg-white/5">
                  Retake
                </button>
              </div>
            </div>
          </div>
        </div>

